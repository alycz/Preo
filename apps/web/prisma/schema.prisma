generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String   @id @default(cuid())
  dynamicUserId        String   @unique
  email                String?
  primaryWalletAddress String?
  agentWalletAddress   String?
  cantonPartyId        String   @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  fundingIntents FundingIntent[]
  agentActions   AgentAction[]
  evmEvents      EvmEvent[]
  policyCaches   PolicyCache[]
  cantonContracts CantonContract[]
}

model FundingIntent {
  id                     String   @id @default(cuid())
  userId                 String
  provider               String
  checkoutId             String?
  transactionId          String?  @unique
  amount                 String
  token                  String
  chainId                Int?
  tokenAddress           String?
  destinationAddress     String?
  externalRef            String?
  logIndex               Int?
  status                 String
  settlementTxHash       String?
  cantonCreditContractId String?
  metadata               Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model EvmEvent {
  id                     String    @id @default(cuid())
  userId                 String?
  chainId                Int
  txHash                 String
  logIndex               Int
  eventName              String
  vaultAddress           String
  tokenAddress           String
  preoUserIdHash         String
  amount                 String
  externalRef            String
  payload                Json
  processedAt            DateTime?
  cantonCreditContractId String?
  createdAt              DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@unique([chainId, txHash, logIndex])
}

model WebhookEvent {
  id             String    @id @default(cuid())
  provider       String
  eventType      String
  eventId        String?
  payload        Json
  signatureValid Boolean
  processedAt    DateTime?
  createdAt      DateTime  @default(now())
}

model AgentAction {
  id                   String   @id @default(cuid())
  userId               String
  actionType           String
  status               String
  dynamicWalletAddress String?
  evmTxHash            String?
  cantonContractId     String?
  pendingActionId      String?
  amount               String?
  asset                String?
  error                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model CantonContract {
  id          String    @id @default(cuid())
  userId      String?
  contractId  String    @unique
  templateId  String
  partyId     String
  status      String
  payload     Json
  createdAt   DateTime  @default(now())
  archivedAt  DateTime?

  user User? @relation(fields: [userId], references: [id])
}

model PolicyCache {
  id               String   @id @default(cuid())
  userId           String
  cantonContractId String
  version          Int
  policyName       String
  categories       Json
  approvalRules    Json
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model DemoParty {
  id            String   @id @default(cuid())
  role          String   @unique
  cantonPartyId String
  displayName   String
  createdAt     DateTime @default(now())
}
