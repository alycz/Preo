{
  "name": "preo",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --filter @preo/web dev",
    "build": "pnpm --filter @preo/web build",
    "typecheck": "pnpm prisma:generate && pnpm --recursive typecheck",
    "test": "pnpm prisma:generate && pnpm --recursive test",
    "verify:demo": "pnpm prisma:generate && pnpm typecheck && pnpm test && pnpm build && pnpm daml:build && pnpm daml:test && DEMO_MODE=true pnpm smoke:canton && DEMO_MODE=true pnpm smoke:dynamic && DEMO_MODE=true pnpm smoke:blink && DEMO_MODE=true pnpm smoke:evm && DEMO_MODE=true pnpm smoke:full-flow",
    "contracts:compile": "pnpm --filter @preo/contracts compile",
    "contracts:test": "pnpm --filter @preo/contracts test",
    "contracts:deploy": "pnpm --filter @preo/contracts deploy",
    "deploy:contracts:local": "pnpm --filter @preo/contracts deploy",
    "deploy:contracts:settlement": "pnpm --filter @preo/contracts deploy -- --network settlement",
    "daml:build": "cd daml && PATH=\"$HOME/.daml/bin:$PATH\" daml build",
    "daml:test": "cd daml && if java -version >/dev/null 2>&1; then PATH=\"$HOME/.daml/bin:$PATH\" daml test; elif [ -x /opt/homebrew/opt/openjdk@17/bin/java ]; then JAVA_HOME=/opt/homebrew/opt/openjdk@17 PATH=\"/opt/homebrew/opt/openjdk@17/bin:$HOME/.daml/bin:$PATH\" daml test; else PATH=\"$HOME/.daml/bin:$PATH\" daml test; fi",
    "daml:test:mac": "cd daml && JAVA_HOME=/opt/homebrew/opt/openjdk@17 PATH=\"/opt/homebrew/opt/openjdk@17/bin:$HOME/.daml/bin:$PATH\" daml test",
    "prisma:generate": "pnpm --filter @preo/web prisma:generate",
    "prisma:migrate": "pnpm --filter @preo/web prisma:migrate",
    "smoke:canton": "tsx scripts/smoke-canton.ts",
    "smoke:dynamic": "tsx scripts/smoke-dynamic.ts",
    "smoke:blink": "tsx scripts/smoke-blink.ts",
    "smoke:evm": "tsx scripts/smoke-evm.ts",
    "smoke:full-flow": "tsx scripts/smoke-full-flow.ts",
    "smoke:live-readiness": "tsx scripts/smoke-live-readiness.ts",
    "prepare:dynamic-agent-wallet": "tsx scripts/prepare-dynamic-agent-wallet.ts",
    "update:canton-deployment": "tsx scripts/update-canton-deployment.ts",
    "demo:direct-vault-deposit": "tsx scripts/demo-direct-vault-deposit.ts",
    "smoke:flow": "pnpm --filter @preo/web smoke:flow",
    "smoke:agent-wallet": "pnpm --filter @preo/web smoke:agent-wallet",
    "smoke:evm-funding": "pnpm --filter @preo/web smoke:evm-funding"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
